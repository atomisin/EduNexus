# EduNexus 2.0 Environment Configuration
# Copy this file to .env and fill in the values

# System
ENVIRONMENT=development
SECRET_KEY=your-32-character-minimum-secret-key-here
DEBUG=True

# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173
# Production: https://your-edunexus-domain.com
ALLOWED_ORIGINS=http://localhost:5173

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_here
POSTGRES_DB=edunexus
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# AI Services
GROQ_API_KEY=gsk_placeholder_key_here
VOICE_API_KEY=your_voice_api_key_here
LLM_PRIMARY_MODEL=groq/llama-3.1-70b-versatile
LLM_FAST_MODEL=groq/llama-3.1-8b-instant
OPENAI_API_KEY=your_openai_key_here
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=30

# Storage (SeaweedFS)
FILER_URL=http://filer:8888
SEAWEEDFS_PASSWORD=seaweed_password_here

# Real-time (LiveKit)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_URL=http://livekit:7800

# Mail (SMTP)
SMTP_TLS=True
SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=nndbiogrkypvsjcc_placeholder

# Features
EMAILS_ENABLED=False
REGISTRATION_ENABLED=True
VERIFICATION_ENABLED=False
